{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AI Profit Pool — company dataset",
  "type": "object",
  "required": ["meta", "companies"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["schema_version", "unit"],
      "properties": {
        "schema_version": {"type": "string"},
        "unit": {"type": "string"},
        "note": {"type": "string"}
      }
    },
    "companies": {
      "type": "array",
      "items": {"$ref": "#/definitions/company"}
    }
  },
  "definitions": {
    "company": {
      "type": "object",
      "required": ["id", "name", "ticker", "region", "sector", "currency", "seg_profit", "status", "years"],
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9_-]+$"},
        "name": {"type": "string"},
        "ticker": {"type": "string"},
        "region": {"type": "string"},
        "sector": {"type": "string"},
        "currency": {"type": "string"},
        "seg_profit": {"enum": ["yes", "partial", "no"]},
        "status": {"enum": ["populated", "pending"]},
        "logo_text": {"type": "string"},
        "logo_class": {"type": "string"},
        "lead": {"type": "string"},
        "fy_note": {"type": "string"},
        "planned_source": {"type": "string"},
        "quote": {"$ref": "#/definitions/quote"},
        "valuation_caveat": {"$ref": "#/definitions/valuation_caveat"},
        "years": {"type": "array", "items": {"$ref": "#/definitions/year"}}
      }
    },
    "quote": {
      "type": "object",
      "description": "Single-slice market snapshot (not a time series). Raw market facts only; PE/PS/FCF yield are derived in Selectors, never stored.",
      "required": ["as_of", "market_cap", "sources"],
      "additionalProperties": false,
      "properties": {
        "as_of": {"type": "string", "format": "date", "description": "Snapshot date, ISO 8601 (YYYY-MM-DD)."},
        "market_cap": {"type": "number", "description": "Market capitalization in USD bn — same unit/口径 as years[].revenue / net_income. The only cross-currency-safe value; use this for all valuation multiples."},
        "price": {"type": ["number", "null"], "description": "Local-currency share price, for display/对账 reference only. Never multiply across currencies."},
        "price_currency": {"type": "string", "description": "ISO 4217 currency of `price` (e.g. JPY, USD). Display only."},
        "sources": {"type": "array", "items": {"$ref": "#/definitions/source"}}
      }
    },
    "valuation_caveat": {
      "type": "object",
      "description": "Honest distortion flags driving derived-layer downgrade (e.g. investment-holding companies like SoftBank whose net margin / PE are skewed by investment gains).",
      "additionalProperties": false,
      "properties": {
        "pe": {"enum": ["ok", "distorted", "na"]},
        "ps": {"enum": ["ok", "distorted", "na"]},
        "fcf_yield": {"enum": ["ok", "distorted", "na"]},
        "note": {"type": "string"}
      }
    },
    "year": {
      "type": "object",
      "required": ["fy", "status"],
      "properties": {
        "fy": {"type": "string"},
        "period_end": {"type": "string"},
        "status": {"enum": ["actual", "forecast"]},
        "revenue": {"type": "number"},
        "gross_margin": {"type": ["number", "null"]},
        "op_income": {"type": ["number", "null"]},
        "net_income": {"type": ["number", "null"]},
        "capex": {"type": ["number", "null"], "description": "Capital expenditures (raw, from cash-flow statement). Sign-neutral magnitude in meta.unit."},
        "cfo": {"type": ["number", "null"], "description": "Net cash from operating activities (raw, from cash-flow statement) in meta.unit."},
        "segments": {"type": "array", "items": {"$ref": "#/definitions/segment"}},
        "reportable_note": {"type": "object"},
        "framework_change": {"type": "string"},
        "consensus_rev": {"type": "string"},
        "consensus_eps": {"type": "string"},
        "anchors": {"type": "array", "items": {"$ref": "#/definitions/anchor"}},
        "sources": {"type": "array", "items": {"$ref": "#/definitions/source"}}
      },
      "allOf": [
        {
          "if": {"properties": {"status": {"const": "actual"}}},
          "then": {"required": ["revenue", "net_income", "sources"]}
        }
      ]
    },
    "segment": {
      "type": "object",
      "required": ["name", "kind", "revenue"],
      "properties": {
        "name": {"type": "string"},
        "kind": {"enum": ["platform", "division", "reportable"]},
        "revenue": {"type": "number"},
        "op_income": {"type": ["number", "null"]},
        "op_margin": {"type": ["number", "null"]},
        "is_ai": {"type": "boolean"}
      }
    },
    "anchor": {
      "type": "object",
      "required": ["label", "value"],
      "properties": {
        "label": {"type": "string"},
        "value": {"type": "string"},
        "note": {"type": "string"},
        "data_status": {"enum": ["official", "guidance", "consensus", "estimate", "derived"]}
      }
    },
    "source": {
      "type": "object",
      "required": ["label", "url", "data_status"],
      "properties": {
        "label": {"type": "string"},
        "url": {"type": "string", "format": "uri"},
        "data_status": {"enum": ["official", "guidance", "consensus", "estimate", "derived"]}
      }
    }
  }
}
